---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'autoskills — Auto-install the best AI skills for your project',
	description = 'Detect your project dependencies and automatically install the best AI agent skills from skills.sh. Supports React, Next.js, Vue, Astro, Tailwind, and 20+ technologies.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://autoskills.sh" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
	</head>
	<body class="bg-[#0a0a0a] text-zinc-300 min-h-screen font-mono">
		<slot />
	</body>
</html>
